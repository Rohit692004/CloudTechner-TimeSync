# Copy this file to `.env` and adjust if needed:  cp .env.example .env
#
# Postgres connection. Must match the port published in docker-compose.yml
# (this project uses 5434 on the host to avoid clashing with a local Postgres
# on the default 5432). If 5434 is also taken on your machine, change the port
# here AND in docker-compose.yml to a free one.
DATABASE_URL="postgresql://timesheet:timesheet@localhost:5434/timesheet"

# Secret used by NextAuth to sign sessions. Generate your own with:
#   npx auth secret         (writes one for you)
#   OR: openssl rand -base64 33
AUTH_SECRET="change-me-to-a-random-string"

# Required for self-hosted/Docker deployments (Vercel sets this automatically).
# Without it, Auth.js rejects requests in production with "UntrustedHost".
# Safe here because Nginx (see PROJECT_PLAN.md §7) sits in front and controls
# the Host header before it reaches this app -- don't expose this app's port
# directly to the internet without a reverse proxy in front of it.
AUTH_TRUST_HOST=true

# Canonical public URL of the deployed app. Required in production so
# Auth.js builds correct absolute callback/redirect URLs. Leave unset for
# local dev (defaults to http://localhost:3000).
# AUTH_URL="https://timesheet.yourdomain.com"

# Microsoft Azure AD / Entra SSO. The app uses the legacy provider id
# "azure-ad" to match the Scout setup, so Azure must include this redirect URI:
# https://orbit.cloudtechner.com/api/auth/callback/azure-ad
# AZURE_AD_CLIENT_ID=""
# AZURE_AD_CLIENT_SECRET=""
# AZURE_AD_TENANT_ID=""

# Production security hardening. Set credentials login to false in production
# so only Microsoft SSO is registered as an auth provider. Keep true/omitted
# locally if you still need seed password logins during development.
# ENABLE_CREDENTIALS_LOGIN=false

# Restrict Microsoft SSO to this email domain before the employee DB lookup.
# Defaults to @cloudtechner.com when omitted.
# SSO_ALLOWED_EMAIL_DOMAIN="@cloudtechner.com"
