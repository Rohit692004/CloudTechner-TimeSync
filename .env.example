# Copy this file to `.env` and adjust if needed:  cp .env.example .env
#
# Postgres connection. Must match the port published in docker-compose.yml
# (this project uses 5434 on the host to avoid clashing with a local Postgres
# on the default 5432). If 5434 is also taken on your machine, change the port
# here AND in docker-compose.yml to a free one.
DATABASE_URL="postgresql://timesheet:timesheet@localhost:5434/timesheet"

# Secret used by NextAuth to sign sessions. Generate your own with:
#   npx auth secret         (writes one for you)
#   OR: openssl rand -base64 33
AUTH_SECRET="change-me-to-a-random-string"
